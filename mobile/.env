# OVO.Web kök URL (Swagger: docs/openapi/swagger.web.v1.full.json — /api/app/*)
EXPO_PUBLIC_API_URL=http://127.0.0.1:5059

# OpenIddict resource owner password (test/OVO.HttpApi.Client.ConsoleTestApp/appsettings.json ile uyumlu)
EXPO_PUBLIC_OIDC_CLIENT_ID=OVO_App
# DbMigrator appsettings ile aynı (OpenIddict gizli istemci)
EXPO_PUBLIC_OIDC_CLIENT_SECRET=1q2w3e*
EXPO_PUBLIC_OIDC_SCOPE=OVO offline_access

# İsteğe bağlı: host çok kiracılı modda kiracı kimliği (GUID)
