## ✅ STANDART KOD PATTERNS

### Backend — AppService
```csharp
public class WardrobeAppService : OvoAppService, IWardrobeAppService
{
    private readonly IRepository<Garment, Guid> _garmentRepository;
    private readonly IAiPipelineService _aiPipeline;

    public WardrobeAppService(
        IRepository<Garment, Guid> garmentRepository,
        IAiPipelineService aiPipeline)
    {
        _garmentRepository = garmentRepository;
        _aiPipeline = aiPipeline;
    }

    [Authorize(OvoPermissions.Wardrobe.Default)]
    public async Task<GarmentDto> AddGarmentAsync(CreateGarmentInput input)
    {
        // 1. NSFW kontrol
        var isClean = await _aiPipeline.CheckNsfwAsync(input.ImageUrl);
        if (!isClean) throw new UserFriendlyException("Bu görsel uygun bulunmadı.");

        // 2. BG kaldır + etiketle
        var processed = await _aiPipeline.ProcessGarmentImageAsync(input.ImageUrl);

        // 3. Entity oluştur
        var garment = new Garment(GuidGenerator.Create(), CurrentUser.Id!.Value)
        {
            Category = processed.Category,
            SubCategory = processed.SubCategory,
            // ...
        };

        await _garmentRepository.InsertAsync(garment, autoSave: true);
        return ObjectMapper.Map<Garment, GarmentDto>(garment);
    }
}
```

### Mobile — Custom Hook
```typescript
// hooks/useWardrobe.ts
export const useWardrobe = () => {
  const { data, isLoading, error, refetch } = useQuery({
    queryKey: ['wardrobe'],
    queryFn: () => WardrobeService.getAll(),
    staleTime: 5 * 60 * 1000, // 5 dk
  });

  const addGarment = useMutation({
    mutationFn: WardrobeService.addGarment,
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['wardrobe'] }),
    onError: (err) => toast.error(err.message),
  });

  return { garments: data, isLoading, error, refetch, addGarment };
};
```

### Mobile — Service
```typescript
// services/wardrobe.service.ts
class WardrobeService {
  async getAll(filter?: WardrobeFilter): Promise<GarmentListDto> {
    const { data } = await api.get('/wardrobe', { params: filter });
    return data;
  }

  async addGarment(input: CreateGarmentInput): Promise<GarmentDto> {
    const formData = new FormData();
    formData.append('image', { uri: input.imageUri, type: 'image/jpeg', name: 'garment.jpg' } as any);
    const { data } = await api.post('/wardrobe/upload', formData, {
      headers: { 'Content-Type': 'multipart/form-data' },
    });
    return data;
  }
}

export default new WardrobeService();
```

