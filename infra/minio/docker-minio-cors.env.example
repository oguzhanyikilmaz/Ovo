# MinIO konteyner ortam değişkenleri — örnek (değerleri kopyalayıp .env veya compose ile kullanın)
# Kaynak: MinIO server CORS ayarı (API düzeyi)

MINIO_API_CORS_ALLOW_ORIGIN=https://app.ornek.com,https://admin.ornek.com

# Geliştirme (Expo web / local SPA):
# MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:8081,http://localhost:19006

# Üretimde geniş wildcard kullanmayın:
# MINIO_API_CORS_ALLOW_ORIGIN=*
